/// Numeric Nyx version, semver-ish: (major << 16) | (minor << 8) | patch
constexpr std::uint32_t VERSION_HEX =
    (@nyx_VERSION_MAJOR@u << 16) | (@nyx_VERSION_MINOR@u << 8) | @nyx_VERSION_PATCH@u;

constexpr std::string_view VERSION_STRING = "@nyx_VERSION@";
